rules_version = '2';

// Firebase Storage Security Rules
service firebase.storage {
  match /b/{bucket}/o {
    
    // Training content - public read, authenticated write
    match /training/{contentType}/{fileName} {
      // Anyone can read training content (videos, images, thumbnails)
      allow read: if true;
      
      // Only authenticated users can upload
      allow write: if request.auth != null;
      
      // Validate file size (100MB for videos, 10MB for images)
      allow write: if request.resource.size < 100 * 1024 * 1024;
    }
    
    // Drops images - public read, authenticated write
    match /drops/{fileName} {
      allow read: if true;
      allow write: if request.auth != null;
      allow write: if request.resource.size < 10 * 1024 * 1024;
    }
    
    // Profile photos - public read, owner write
    match /profiles/{userId}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
      allow write: if request.resource.size < 5 * 1024 * 1024;
    }
    
    // Collector application documents - private
    match /applications/{userId}/{fileName} {
      allow read: if request.auth != null && 
                     (request.auth.uid == userId || 
                      request.auth.token.roles.hasAny(['admin', 'super_admin']));
      allow write: if request.auth != null && request.auth.uid == userId;
      allow write: if request.resource.size < 10 * 1024 * 1024;
    }
    
    // Default: deny all other access
    match /{allPaths=**} {
      allow read: if false;
      allow write: if false;
    }
  }
}

