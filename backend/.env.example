# ============================================
# Environment Variables Template
# ============================================
# Copy this file to .env and fill in your values
# NEVER commit .env to git (it's in .gitignore)
# ============================================

# ============================================
# REQUIRED - Production
# ============================================
# JWT secret key (minimum 32 characters, use a strong random string)
JWT_SECRET=your-super-secret-jwt-key-minimum-32-characters-long

# MongoDB connection string
# Format: mongodb://[username:password@]host[:port][/database][?options]
MONGODB_URI=mongodb://localhost:27017/eco_collect

# Environment (development, production, test)
NODE_ENV=development

# ============================================
# OPTIONAL - Server Configuration
# ============================================
# Server port (default: 3000)
PORT=3000

# JWT token expiration (default: 7d)
# Examples: 1h, 24h, 7d, 30d
JWT_EXPIRES_IN=7d

# ============================================
# OPTIONAL - Email Service (Gmail)
# ============================================
# Gmail account for sending OTP emails
# Note: Use App Password, not regular password
# https://support.google.com/accounts/answer/185833
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-gmail-app-password

# ============================================
# OPTIONAL - Google Maps API
# ============================================
# Google Maps API key for geocoding and maps
# Get from: https://console.cloud.google.com/apis/credentials
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# ============================================
# OPTIONAL - Firebase (FCM Notifications)
# ============================================
# Option 1: Use environment variable (recommended for production)
# Paste the entire JSON as a single-line string
# FIREBASE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"...","client_email":"...","client_id":"...","auth_uri":"...","token_uri":"...","auth_provider_x509_cert_url":"...","client_x509_cert_url":"..."}

# Option 2: Use file (development only)
# Place firebase-service-account.json in backend/ directory
# File is automatically detected if env var is not set

# ============================================
# OPTIONAL - CORS Configuration
# ============================================
# Comma-separated list of allowed origins
# Required in production, optional in development (allows all)
# Examples:
#   Development: http://localhost:3001,http://localhost:3000
#   Production: https://app.example.com,https://admin.example.com
ALLOWED_ORIGINS=http://localhost:3001,http://localhost:3000
